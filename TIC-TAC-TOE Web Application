        <!-- Cell 7 -->
        <button data-index="7" class="game-cell cell-glow flex items-center justify-center rounded-2xl bg-brand-card border border-slate-700/30 text-4xl sm:text-5xl font-display font-extrabold focus:outline-none transition-all duration-200 hover:bg-slate-800/30 hover:border-slate-600/50 text-slate-600 focus:ring-2 focus:ring-indigo-500/50" aria-label="Square 8"></button>
        <!-- Cell 8 -->
        <button data-index="8" class="game-cell cell-glow flex items-center justify-center rounded-2xl bg-brand-card border border-slate-700/30 text-4xl sm:text-5xl font-display font-extrabold focus:outline-none transition-all duration-200 hover:bg-slate-800/30 hover:border-slate-600/50 text-slate-600 focus:ring-2 focus:ring-indigo-500/50" aria-label="Square 9"></button>
      </div>

      <!-- Floating AI Thinking Overlay (Only visible when AI is processing) -->
      <div id="ai-thinking" class="absolute inset-0 bg-slate-950/80 rounded-3xl flex flex-col items-center justify-center gap-3 opacity-0 pointer-events-none transition-all duration-300 z-20">
