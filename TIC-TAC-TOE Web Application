  </main>

  <!-- Interactive Footer info -->
  <footer class="py-4 text-center border-t border-slate-900 bg-brand-darker text-slate-500 text-xs mt-8">
    <div class="flex items-center justify-center gap-1">
      <span>Built with extreme precision</span>
      <i class="fa-solid fa-bolt text-amber-500"></i>
    </div>
  </footer>

  <!-- Script Logic -->
  <script>
    
    class GameAudio {
      constructor() {
        this.enabled = true;
        this.ctx = null;
      }

      init() {
        if (!this.ctx) {
          this.ctx = new (window.AudioContext || window.webkitAudioContext)();
        }
      }

      playTone(freq, type, duration, delay = 0) {
        if (!this.enabled) return;
        this.init();
        
        setTimeout(() => {
          try {
            const osc = this.ctx.createOscillator();
            const gain = this.ctx.createGain();
            
            osc.type = type;
            osc.frequency.setValueAtTime(freq, this.ctx.currentTime);
            
            gain.gain.setValueAtTime(0.15, this.ctx.currentTime);
            // Smooth release
            gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + duration);
            
            osc.connect(gain);
            gain.connect(this.ctx.destination);
            
            osc.start();
            osc.stop(this.ctx.currentTime + duration);
          } catch (e) {
            console.warn("Audio Context blocked or failed:", e);
          }
        }, delay * 1000);
      }

      playX() {
        this.playTone(330, 'triangle', 0.15); 
      }

      playO() {
        this.playTone(440, 'sine', 0.18); 
      }

      playWin() {
        
        this.playTone(261.63, 'sine', 0.2, 0);   
        this.playTone(329.63, 'sine', 0.2, 0.1); 
        this.playTone(392.00, 'sine', 0.2, 0.2); 
        this.playTone(523.25, 'sine', 0.4, 0.3); 
      }

      playTie() {
        // Gentle neutral tone
        this.playTone(220, 'sawtooth', 0.3, 0);   
        this.playTone(196, 'sawtooth', 0.4, 0.15); 
      }

      playReset() {
        this.playTone(587.33, 'triangle', 0.1, 0);   
        this.playTone(293.66, 'triangle', 0.2, 0.08); 
      }
    }

    
    class Confetti {
      constructor(canvasId) {
        this.canvas = document.getElementById(canvasId);
        this.ctx = this.canvas.getContext('2d');
        this.particles = [];
        this.active = false;
        
        window.addEventListener('resize', () => this.resize());
        this.resize();
      }

      resize() {
        this.canvas.width = this.canvas.parentElement.clientWidth || window.innerWidth;
        this.canvas.height = this.canvas.parentElement.clientHeight || window.innerHeight;
      }

      spawn(count = 100) {
        this.particles = [];
        for (let i = 0; i < count; i++) {
          this.particles.push({
            x: Math.random() * this.canvas.width,
            y: -10 - Math.random() * 20,
            size: Math.random() * 6 + 4,
            speedY: Math.random() * 4 + 2,
            speedX: Math.random() * 4 - 2,
            color: `hsl(${Math.random() * 360}, 85%, 60%)`,
            rotation: Math.random() * 360,
            rotSpeed: Math.random() * 4 - 2
          });
        }
        if (!this.active) {
          this.active = true;
          this.animate();
        }
      }

      animate() {
        if (!this.active) return;
        this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        
        let alive = false;
        
        this.particles.forEach(p => {
          p.y += p.speedY;
          p.x += p.speedX;
          p.rotation += p.rotSpeed;

          if (p.y < this.canvas.height) {
            alive = true;
          }

          this.ctx.save();
          this.ctx.translate(p.x, p.y);
          this.ctx.rotate(p.rotation * Math.PI / 180);
          this.ctx.fillStyle = p.color;
          this.ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size);
          this.ctx.restore();
        });

        if (alive) {
          requestAnimationFrame(() => this.animate());
        } else {
          this.active = false;
          this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
        }
      }
    }

    
    const App = {
      // Game State
      board: Array(9).fill(null),
      currentPlayer: 'X', 
      gameActive: true,
      gameMode: 'single', 
      difficulty: 'hard', 
      scores: {
        X: 0,
        O: 0,
        ties: 0
      },

      
      winningCombinations: [
        [0, 1, 2], [3, 4, 5], [6, 7, 8], 
        [0, 3, 6], [1, 4, 7], [2, 5, 8], 
        [0, 4, 8], [2, 4, 6]             
      ],

      
      audio: new GameAudio(),
      confetti: null,

      init() {
        this.confetti = new Confetti('confetti-canvas');
        this.cacheDOM();
        this.bindEvents();
        this.resetBoard();
        this.updateScoreboardUI();
      },

      cacheDOM() {
        this.cells = document.querySelectorAll('.game-cell');
        this.btnRestart = document.getElementById('btn-restart');
        this.btnResetScores = document.getElementById('btn-reset-scores');
        
        this.modeSingle = document.getElementById('mode-single');
        this.modeMulti = document.getElementById('mode-multi');
        this.diffWrapper = document.getElementById('difficulty-wrapper');
        
        this.diffEasy = document.getElementById('diff-easy');
        this.diffMedium = document.getElementById('diff-medium');
        this.diffHard = document.getElementById('diff-hard');
        
        this.scoreX = document.getElementById('score-x');
        this.scoreO = document.getElementById('score-o');
        this.scoreTies = document.getElementById('score-ties');
        
        this.cardX = document.getElementById('card-x');
        this.cardO = document.getElementById('card-o');
        this.oLabel = document.getElementById('o-label');
        
        this.turnBadgeX = document.getElementById('turn-badge-x');
        this.turnBadgeO = document.getElementById('turn-badge-o');
        
        this.soundToggle = document.getElementById('sound-toggle');
        this.soundIcon = document.getElementById('sound-icon');
        
        this.aiThinking = document.getElementById('ai-thinking');
        this.statusBanner = document.getElementById('status-banner');
      },

      bindEvents() {
        
        this.cells.forEach(cell => {
          cell.addEventListener('click', (e) => this.handleCellClick(e));
        });

    
        this.btnRestart.addEventListener('click', () => {
          this.audio.playReset();
          this.resetBoard();
        });
        
        this.btnResetScores.addEventListener('click', () => {
          this.audio.playReset();
          this.resetScores();
        });

        
        this.modeSingle.addEventListener('click', () => this.setGameMode('single'));
        this.modeMulti.addEventListener('click', () => this.setGameMode('multi'));


        this.diffEasy.addEventListener('click', () => this.setDifficulty('easy'));
        this.diffMedium.addEventListener('click', () => this.setDifficulty('medium'));
        this.diffHard.addEventListener('click', () => this.setDifficulty('hard'));

        
        this.soundToggle.addEventListener('click', () => this.toggleSound());
      },

      toggleSound() {
        this.audio.enabled = !this.audio.enabled;
        if (this.audio.enabled) {
          this.soundIcon.className = "fa-solid fa-volume-high";
          this.audio.playX();
        } else {
          this.soundIcon.className = "fa-solid fa-volume-xmark text-rose-500";
        }
      },

      setGameMode(mode) {
        if (this.gameMode === mode) return;
        this.gameMode = mode;
        this.audio.playReset();

        
        if (mode === 'single') {
          this.modeSingle.className = "mode-btn py-2.5 px-3 rounded-xl border font-semibold text-sm transition-all duration-300 flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-indigo-600 border-indigo-500 text-white shadow-lg shadow-indigo-950/40";
          this.modeMulti.className = "mode-btn py-2.5 px-3 rounded-xl border border-slate-700/60 bg-slate-800/40 text-slate-300 font-semibold text-sm transition-all duration-300 flex items-center justify-center gap-2 hover:bg-slate-800 hover:text-white";
          
          this.diffWrapper.style.maxHeight = '100px';
          this.diffWrapper.style.opacity = '1';
          this.oLabel.innerHTML = '<span>O (Computer)</span>';
        } else {
          this.modeMulti.className = "mode-btn py-2.5 px-3 rounded-xl border font-semibold text-sm transition-all duration-300 flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-indigo-600 border-indigo-500 text-white shadow-lg shadow-indigo-950/40";
          this.modeSingle.className = "mode-btn py-2.5 px-3 rounded-xl border border-slate-700/60 bg-slate-800/40 text-slate-300 font-semibold text-sm transition-all duration-300 flex items-center justify-center gap-2 hover:bg-slate-800 hover:text-white";
          
          this.diffWrapper.style.maxHeight = '0px';
          this.diffWrapper.style.opacity = '0';
          this.oLabel.innerHTML = '<span>O (Player 2)</span>';
        }

        this.resetScores();
        this.resetBoard();
      },

      setDifficulty(level) {
        if (this.difficulty === level) return;
        this.difficulty = level;
        this.audio.playReset();

        const activeClasses = "diff-btn py-1.5 px-2 rounded-lg text-xs font-semibold bg-indigo-600/20 text-indigo-400 border border-indigo-500/30 transition-all";
        const inactiveClasses = "diff-btn py-1.5 px-2 rounded-lg text-xs font-medium text-slate-400 hover:text-slate-200 transition-all";

        this.diffEasy.className = level === 'easy' ? activeClasses : inactiveClasses;
        this.diffMedium.className = level === 'medium' ? activeClasses : inactiveClasses;
        this.diffHard.className = level === 'hard' ? activeClasses : inactiveClasses;

        this.resetScores();
        this.resetBoard();
      },

      resetBoard() {
        this.board = Array(9).fill(null);
        this.currentPlayer = 'X';
        this.gameActive = true;
        this.statusBanner.classList.add('hidden');

        this.cells.forEach(cell => {
          cell.innerHTML = '';
          cell.className = "game-cell cell-glow flex items-center justify-center rounded-2xl bg-brand-card border border-slate-700/30 text-4xl sm:text-5xl font-display font-extrabold focus:outline-none transition-all duration-200 hover:bg-slate-800/30 hover:border-slate-600/50 text-slate-600 focus:ring-2 focus:ring-indigo-500/50";
        });

        this.updateActiveIndicators();
      },

      resetScores() {
        this.scores = { X: 0, O: 0, ties: 0 };
        this.updateScoreboardUI();
      },

      updateScoreboardUI() {
        this.scoreX.innerText = this.scores.X;
        this.scoreO.innerText = this.scores.O;
        this.scoreTies.innerText = this.scores.ties;
      },

      updateActiveIndicators() {
        if (this.currentPlayer === 'X') {
          this.turnBadgeX.classList.remove('hidden');
          this.turnBadgeO.classList.add('hidden');
          
          this.cardX.classList.add('border-blue-500/40', 'bg-blue-950/10');
          this.cardO.classList.remove('border-pink-500/40', 'bg-pink-950/10');
        } else {
          this.turnBadgeO.classList.remove('hidden');
          this.turnBadgeX.classList.add('hidden');
          
          this.cardO.classList.add('border-pink-500/40', 'bg-pink-950/10');
          this.cardX.classList.remove('border-blue-500/40', 'bg-blue-950/10');
        }
      },

      handleCellClick(e) {
        const index = parseInt(e.currentTarget.getAttribute('data-index'));

        
        if (this.board[index] || !this.gameActive || (this.gameMode === 'single' && this.currentPlayer === 'O')) return;

        this.makeMove(index, this.currentPlayer);

        if (this.gameActive && this.gameMode === 'single' && this.currentPlayer === 'O') {
          this.triggerAIMove();
        }
      },

      makeMove(index, player) {
        this.board[index] = player;

        
        const cell = this.cells[index];
        if (player === 'X') {
          cell.innerHTML = `<span class="animate-scale-up text-blue-400 font-display"><i class="fa-solid fa-xmark"></i></span>`;
          cell.classList.add('neon-border-x', 'border-blue-500/30');
          this.audio.playX();
        } else {
          cell.innerHTML = `<span class="animate-scale-up text-pink-400 font-display"><i class="fa-solid fa-circle-notch"></i></span>`;
          cell.classList.add('neon-border-o', 'border-pink-500/30');
          this.audio.playO();
        }

        const winResult = this.checkWin(this.board, player);

        if (winResult) {
          this.handleWin(player, winResult);
        } else if (this.checkTie(this.board)) {
          this.handleTie();
        } else {
          
          this.currentPlayer = this.currentPlayer === 'X' ? 'O' : 'X';
          this.updateActiveIndicators();
        }
      },

      triggerAIMove() {
        
        this.aiThinking.style.opacity = '1';
        this.aiThinking.style.pointerEvents = 'auto';

        const delay = Math.random() * 400 + 350; 

        setTimeout(() => {
          this.aiThinking.style.opacity = '0';
          this.aiThinking.style.pointerEvents = 'none';

          if (!this.gameActive) return;

          const bestMove = this.getBestMove();
          if (bestMove !== null) {
            this.makeMove(bestMove, 'O');
          }
        }, delay);
      },

      
      getBestMove() {
        const availableIndices = this.board.map((val, idx) => val === null ? idx : null).filter(val => val !== null);
        
        if (availableIndices.length === 0) return null;

        
        if (this.difficulty === 'easy') {
          return availableIndices[Math.floor(Math.random() * availableIndices.length)];
        }

        
        if (this.difficulty === 'medium') {
          if (Math.random() < 0.5) {
            return availableIndices[Math.floor(Math.random() * availableIndices.length)];
          }
          
        }

        
        let bestScore = -Infinity;
        let move = null;

        for (let i = 0; i < 9; i++) {
          if (this.board[i] === null) {
            this.board[i] = 'O';
            let score = this.minimax(this.board, 0, false, -Infinity, Infinity);
            this.board[i] = null;
            if (score > bestScore) {
              bestScore = score;
              move = i;
            }
          }
        }
        return move;
      },

      
      minimax(boardState, depth, isMaximizing, alpha, beta) {
        
        if (this.checkWin(boardState, 'O')) return 10 - depth;
        if (this.checkWin(boardState, 'X')) return depth - 10;
        if (this.checkTie(boardState)) return 0;

        if (isMaximizing) {
          let maxEval = -Infinity;
          for (let i = 0; i < 9; i++) {
            if (boardState[i] === null) {
              boardState[i] = 'O';
              let evalVal = this.minimax(boardState, depth + 1, false, alpha, beta);
              boardState[i] = null;
              maxEval = Math.max(maxEval, evalVal);
              alpha = Math.max(alpha, evalVal);
              if (beta <= alpha) break; // Pruning
            }
          }
          return maxEval;
        } else {
          let minEval = Infinity;
          for (let i = 0; i < 9; i++) {
            if (boardState[i] === null) {
              boardState[i] = 'X';
              let evalVal = this.minimax(boardState, depth + 1, true, alpha, beta);
              boardState[i] = null;
              minEval = Math.min(minEval, evalVal);
              beta = Math.min(beta, evalVal);
              if (beta <= alpha) break; 
            }
          }
          return minEval;
        }
      },

      checkWin(boardState, player) {
        for (let i = 0; i < this.winningCombinations.length; i++) {
          const [a, b, c] = this.winningCombinations[i];
          if (boardState[a] === player && boardState[b] === player && boardState[c] === player) {
            return this.winningCombinations[i]; 
          }
        }
        return null;
      },

      checkTie(boardState) {
        return boardState.every(cell => cell !== null);
      },

      handleWin(winner, winningLine) {
        this.gameActive = false;
        this.scores[winner]++;
        this.updateScoreboardUI();

        
        winningLine.forEach(idx => {
          this.cells[idx].classList.add('winning-cell');
        });

        // Presentation Effects
        this.audio.playWin();
        this.confetti.spawn(120);

        
        this.statusBanner.classList.remove('hidden');
        if (this.gameMode === 'single') {
          if (winner === 'X') {
            this.statusBanner.innerText = "Awesome! You defeated the AI!";
            this.statusBanner.className = "w-full mt-4 text-center text-sm font-semibold py-2.5 px-4 rounded-xl border border-dashed border-emerald-500/40 bg-emerald-500/10 text-emerald-400";
          } else {
            this.statusBanner.innerText = "The Computer wins! Keep training!";
            this.statusBanner.className = "w-full mt-4 text-center text-sm font-semibold py-2.5 px-4 rounded-xl border border-dashed border-rose-500/40 bg-rose-500/10 text-rose-400";
          }
        } else {
          this.statusBanner.innerText = `Congratulations, Player ${winner} wins!`;
          this.statusBanner.className = `w-full mt-4 text-center text-sm font-semibold py-2.5 px-4 rounded-xl border border-dashed ${winner === 'X' ? 'border-blue-500/40 bg-blue-500/10 text-blue-400' : 'border-pink-500/40 bg-pink-500/10 text-pink-400'}`;
        }
      },

      handleTie() {
        this.gameActive = false;
        this.scores.ties++;
        this.updateScoreboardUI();
        this.audio.playTie();

        this.statusBanner.classList.remove('hidden');
        this.statusBanner.innerText = "Good game! It's an even Draw!";
        this.statusBanner.className = "w-full mt-4 text-center text-sm font-semibold py-2.5 px-4 rounded-xl border border-dashed border-slate-500/40 bg-slate-500/10 text-slate-300";
      }
    };

    
    window.addEventListener('DOMContentLoaded', () => {
      App.init();
    });
  </script>
