        <!-- Cell 2 -->
        <button data-index="2" class="game-cell cell-glow flex items-center justify-center rounded-2xl bg-brand-card border border-slate-700/30 text-4xl sm:text-5xl font-display font-extrabold focus:outline-none transition-all duration-200 hover:bg-slate-800/30 hover:border-slate-600/50 text-slate-600 focus:ring-2 focus:ring-indigo-500/50" aria-label="Square 3"></button>
        <!-- Cell 3 -->
